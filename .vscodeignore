# 开发文件
.vscode/**
.vscode-test/**
.gitignore
tsconfig.json
*.map
*.vsix
.limcode/**
fast-tavern-main/**
.tmp/**
*.ts
!*.d.ts

# 锁文件
pnpm-lock.yaml
package-lock.json
yarn.lock

# 测试相关（不打包进扩展）
test/**
jest.config.cjs
jest.backend.config.js
tsconfig.jest.json
tsconfig.test.json
coverage/**
.jest-cache/**
.ts-jest/**
.cache/**

# 临时/本地文件（不打包）
diff_analyzer.py
limcode-settings.json

# 日志文件（本地调试产物不打包）
*.log
*.log.*
logs/**

# 后端源文件和文档（只需要 dist 中的编译结果）
backend/**
webview/**

# 前端源文件（只需要 dist）
frontend/src/**
frontend/node_modules/**
frontend/*.json
frontend/*.ts
frontend/*.html
frontend/tsconfig*.json
frontend/vite.config.ts
frontend/pnpm-lock.yaml
frontend/COMPONENT_ARCHITECTURE.md

# 忽略所有 node_modules，但保留需要的运行时依赖
node_modules/**
!node_modules/
!node_modules/@vscode/
!node_modules/@vscode/**
